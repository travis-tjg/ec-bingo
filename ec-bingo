  1. Create a FREE Supabase project at https://supabase.com
  2. In the SQL editor, run this:
  
     create table bingo_state (
       id text primary key,
       player text not null,
       squares jsonb not null,
       marked jsonb not null,
       updated_at timestamptz default now()
     );
     alter table bingo_state enable row level security;
     create policy "Public read" on bingo_state for select using (true);
     create policy "Public write" on bingo_state for insert with check (true);
     create policy "Public update" on bingo_state for update using (true);
  
  3. Replace the two values below with your project URL and anon key
-->
<script>
  const SUPABASE_URL = 'YOUR_SUPABASE_URL';
  const SUPABASE_ANON_KEY = 'YOUR_SUPABASE_ANON_KEY';
</script>
<!-- ███████████████████████████████████████████████████ -->

<div id="configNotice" style="display:none">
  ⚠️ Supabase not configured yet. <a href="#" onclick="document.getElementById('configNotice').style.display='none'">Dismiss (local-only mode)</a>
</div>

<div id="toast"></div>

<!-- SETUP -->
<div id="setupScreen">
  <div class="setup-box">
    <div class="setup-title">BINGO</div>
    <div class="setup-sub">Meeting Survival Game</div>

    <label class="name-label">Your name</label>
    <input class="name-input" id="nameInput" type="text" placeholder="Enter your name..." maxlength="20" />

    <div class="player-pills" id="quickPicks">
      <button class="player-pill" onclick="pickName('Travis')">Travis</button>
      <button class="player-pill" onclick="pickName('Paige')">Paige</button>
      <button class="player-pill" onclick="pickName('MaryClare')">MaryClare</button>
    </div>

    <button class="join-btn" onclick="joinGame()">LET'S PLAY 🎰</button>
  </div>
</div>

<!-- GAME -->
<div id="gameScreen">
  <div class="game-header">
    <div class="game-title">MEETING BINGO 🎰</div>
    <div class="online-players">
      <div class="online-dot"></div>
      <div class="online-label" id="onlineCount">1 playing</div>
    </div>
    <button class="leave-btn" onclick="leaveGame()">Leave</button>
  </div>
  <div class="boards-area" id="boardsArea">
    <div class="waiting-msg" id="waitingMsg">Waiting for other players to join...</div>
  </div>
</div>

<script>
// ── CONFIG CHECK ──
if (SUPABASE_URL === 'YOUR_SUPABASE_URL') {
  document.getElementById('configNotice').style.display = 'block';
}

// ── SUPABASE INIT ──
let sbClient = null;
try {
  sbClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
} catch(e) {}

// ── BINGO SQUARES ──
const ALL_SQUARES = [
  "Yelp",
  "Walking around doing nothing",
  "Humberto",
  "Build itself",
  "NEO",
  "I did more local yesterday...",
  "Instant BINGO if she doesn't join!!",
  "Caleb starts talking thinking he's on mute",
  "People asking what I should be doing",
  "Someone asks to be muted",
  "Someone says something about Bob or Deanna",
  "Blog post topics",
  "Technical difficulties",
  "Can everyone hear me?",
  "Sorry I was on mute",
  "Let's take this offline",
  "Quick question",
  "Moving forward",
  "Circle back",
  "Just to piggyback on that",
  "Can you share your screen?",
  "Low battery warning",
  "Background noise",
  "Sorry I joined late",
];

const COLORS = ['#FFE135','#FF6B9D','#4ECDC4','#FF8C42','#9B5DE5'];

// ── STATE ──
let myName = '';
let myId = '';
let mySquares = [];
let myMarked = [];
let allPlayers = {};
let subscription = null;
let playerOrder = [];

// ── UTILS ──
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function checkWin(marked) {
  for (let r = 0; r < 5; r++) {
    if ([0,1,2,3,4].every(c => marked[r*5+c])) return true;
  }
  for (let c = 0; c < 5; c++) {
    if ([0,1,2,3,4].every(r => marked[r*5+c])) return true;
  }
  if ([0,6,12,18,24].every(i => marked[i])) return true;
  if ([4,8,12,16,20].every(i => marked[i])) return true;
  return false;
}

function showToast(msg, duration = 2500) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), duration);
}

function playerThemeIndex(playerId) {
  if (!playerOrder.includes(playerId)) playerOrder.push(playerId);
  return playerOrder.indexOf(playerId) % 5;
}

// ── SETUP ──
window.pickName = pickName;
window.joinGame = joinGame;
window.leaveGame = leaveGame;

function pickName(name) {
  document.getElementById('nameInput').value = name;
  document.querySelectorAll('.player-pill').forEach(p => {
    p.classList.toggle('active', p.textContent === name);
  });
}

document.getElementById('nameInput').addEventListener('input', function() {
  document.querySelectorAll('.player-pill').forEach(p => p.classList.remove('active'));
});

document.getElementById('nameInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') joinGame();
});

function joinGame() {
  const name = document.getElementById('nameInput').value.trim();
  if (!name) { showToast('Enter your name first!'); return; }

  myName = name;
  myId = name.toLowerCase().replace(/\s+/g, '_') + '_' + Math.random().toString(36).slice(2, 6);

  const shuffled = shuffle(ALL_SQUARES).slice(0, 24);
  shuffled.splice(12, 0, 'FREE SPACE');
  mySquares = shuffled;
  myMarked = new Array(25).fill(false);
  myMarked[12] = true;

  document.getElementById('setupScreen').style.display = 'none';
  document.getElementById('gameScreen').style.display = 'block';

  startGame();
}

// ── GAME ──
async function startGame() {
  if (!sbClient || SUPABASE_URL === 'YOUR_SUPABASE_URL') {
    // Local-only mode
    allPlayers[myId] = { id: myId, player: myName, squares: mySquares, marked: myMarked };
    renderBoards();
    return;
  }

  // Push my board to Supabase
  await sbClient.from('bingo_state').upsert({
    id: myId,
    player: myName,
    squares: mySquares,
    marked: myMarked,
    updated_at: new Date().toISOString()
  });

  // Load existing players
  const { data } = await sbClient.from('bingo_state').select('*');
  if (data) {
    data.forEach(row => {
      allPlayers[row.id] = row;
    });
  }

  renderBoards();

  // Subscribe to realtime changes
  subscription = sbClient
    .channel('bingo_room')
    .on('postgres_changes', { event: '*', schema: 'public', table: 'bingo_state' }, payload => {
      const row = payload.new;
      if (!row || !row.id) return;
      const isNew = !allPlayers[row.id];
      allPlayers[row.id] = row;
      if (isNew && row.id !== myId) {
        showToast(`${row.player} joined the game!`);
      }
      renderBoards();
    })
    .subscribe();
}

function renderBoards() {
  const area = document.getElementById('boardsArea');
  const players = Object.values(allPlayers);

  // Sort: me first, then others by name
  players.sort((a, b) => {
    if (a.id === myId) return -1;
    if (b.id === myId) return 1;
    return a.player.localeCompare(b.player);
  });

  // Update online count
  document.getElementById('onlineCount').textContent =
    players.length === 1 ? '1 playing' : `${players.length} playing`;

  document.getElementById('waitingMsg').style.display = players.length <= 1 ? 'block' : 'none';

  // Remove cards no longer present
  area.querySelectorAll('.card-wrap[data-pid]').forEach(el => {
    if (!allPlayers[el.dataset.pid]) el.remove();
  });

  players.forEach(p => {
    const themeIdx = playerThemeIndex(p.id);
    const isMine = p.id === myId;
    const existingWrap = area.querySelector(`.card-wrap[data-pid="${p.id}"]`);

    if (existingWrap) {
      // Just update cells
      updateCardCells(existingWrap, p, isMine);
      return;
    }

    const wrap = document.createElement('div');
    wrap.className = `card-wrap theme-${themeIdx}`;
    wrap.dataset.pid = p.id;

    const badge = document.createElement('div');
    badge.className = 'player-badge';
    badge.textContent = isMine ? `${p.player} (you)` : p.player;

    const card = document.createElement('div');
    card.className = 'bingo-card' + (isMine ? ' is-mine' : '');

    // Header
    const headerRow = document.createElement('div');
    headerRow.className = 'bingo-header-row';
    ['B','I','N','G','O'].forEach(l => {
      const el = document.createElement('div');
      el.className = 'bingo-letter';
      el.textContent = l;
      headerRow.appendChild(el);
    });

    // Grid
    const grid = document.createElement('div');
    grid.className = 'bingo-grid';
    grid.dataset.pid = p.id;

    p.squares.forEach((text, i) => {
      const cell = document.createElement('div');
      cell.className = 'bingo-cell' + (i === 12 ? ' free-space' : '') + (p.marked[i] ? ' marked' : '') + (isMine ? ' is-mine' : '');
      cell.dataset.index = i;
      cell.textContent = text;

      if (isMine && i !== 12) {
        cell.addEventListener('click', () => toggleCell(i, cell));
      }

      grid.appendChild(cell);
    });

    // Win banner
    const winStrip = document.createElement('div');
    winStrip.className = 'win-strip' + (checkWin(p.marked) ? ' show' : '');
    winStrip.textContent = `🎉 BINGO! ${p.player} wins!`;

    card.appendChild(headerRow);
    card.appendChild(grid);
    card.appendChild(winStrip);

    wrap.appendChild(badge);
    wrap.appendChild(card);
    area.appendChild(wrap);
  });
}

function updateCardCells(wrap, p, isMine) {
  const grid = wrap.querySelector('.bingo-grid');
  if (!grid) return;
  const cells = grid.querySelectorAll('.bingo-cell');
  cells.forEach((cell, i) => {
    cell.classList.toggle('marked', !!p.marked[i]);
  });
  const winStrip = wrap.querySelector('.win-strip');
  if (winStrip) {
    const won = checkWin(p.marked);
    winStrip.classList.toggle('show', won);
    winStrip.textContent = `🎉 BINGO! ${p.player} wins!`;
  }
}

async function toggleCell(index, cellEl) {
  myMarked[index] = !myMarked[index];
  cellEl.classList.toggle('marked', myMarked[index]);
  cellEl.classList.add('cell-ping');
  setTimeout(() => cellEl.classList.remove('cell-ping'), 300);

  const won = checkWin(myMarked);

  // Update local state
  allPlayers[myId] = { ...allPlayers[myId], marked: [...myMarked] };

  // Update win banner immediately
  const myWrap = document.querySelector(`.card-wrap[data-pid="${myId}"]`);
  if (myWrap) {
    const winStrip = myWrap.querySelector('.win-strip');
    if (winStrip) {
      winStrip.classList.toggle('show', won);
      if (won) showToast('🎉 BINGO! You win!', 4000);
    }
  }

  // Push to Supabase
  if (sbClient if (supabase && if (supabase &&  SUPABASE_URL !== 'YOUR_SUPABASE_URL') {
    await sbClient.from('bingo_state').update({
      marked: myMarked,
      updated_at: new Date().toISOString()
    }).eq('id', myId);
  }
}

async function leaveGame() {
  if (sbClient if (supabase && if (supabase &&  SUPABASE_URL !== 'YOUR_SUPABASE_URL') {
    await sbClient.from('bingo_state').delete().eq('id', myId);
    if (subscription) sbClient.removeChannel(subscription);
  }
  allPlayers = {};
  playerOrder = [];
  myName = '';
  myId = '';
  document.getElementById('boardsArea').innerHTML = '<div class="waiting-msg" id="waitingMsg">Waiting for other players to join...</div>';
  document.getElementById('gameScreen').style.display = 'none';
  document.getElementById('setupScreen').style.display = 'flex';
}
</script>
